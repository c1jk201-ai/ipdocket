# =============================================================================
# IP Docket System Environment Example
# =============================================================================
# Copy this file to .env and fill in deployment-specific values.

# Flask / app
FLASK_ENV=development
FLASK_DEBUG=False
SECRET_KEY=change-me-to-a-long-random-string
BASE_URL=http://127.0.0.1:5000
APP_BIND_IP=127.0.0.1
APP_PORT=5000
DB_BIND_IP=127.0.0.1
TIMEZONE=America/New_York
LOCALE=en-US
DATE_FORMAT=%m/%d/%Y
DATETIME_FORMAT=%m/%d/%Y %I:%M:%S %p
DATETIME_MINUTE_FORMAT=%m/%d/%Y %I:%M %p

# Local login
ALLOW_PASSWORD_LOGIN=true
LOCAL_ADMIN_BOOTSTRAP_ENABLED=false
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=change-me-now
LOCAL_ADMIN_EMAIL=admin@example.com
LOCAL_ADMIN_DISPLAY_NAME=Administrator
ENABLE_TEST_ACCOUNTS=false
AUTH_REMEMBER_ENABLED=false

# Database
DATABASE_URL=postgresql://ipm:change-me@localhost:5432/ipm
POSTGRES_USER=ipm
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ipm
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_PRE_PING=true
DB_WAIT_ON_START=1
DB_WAIT_TIMEOUT_SECONDS=120
DB_SCHEMA_AUTO_CREATE=1

# Redis / rate limiting
REDIS_PASSWORD=replace-with-random-redis-password
RATELIMIT_STORAGE_URI=redis://:replace-with-random-redis-password@redis:6379/1
RATELIMIT_DEFAULTS="1000 per hour"
RATELIMIT_REQUIRE_SHARED_STORAGE=1
RATELIMIT_IN_MEMORY_FALLBACK_ENABLED=0

# Security / access control
SECURITY_TRUST_PROXY_HEADERS=false
SECURITY_INTERNAL_CIDRS=
ADMIN_CIDR_ALLOWLIST=
INTERNAL_API_CIDR_ALLOWLIST=
CIDR_GUARD_ENABLED=true
POLICY_ENGINE_ENABLED=true
POLICY_RAW_SQL_GUARD_MODE=report

# Runtime / performance
PERF_HEADERS_ENABLED=false
USER_ACCESS_LOG_ENABLED=true
USER_ACCESS_LOG_ASYNC_ENABLED=true
USER_ACCESS_LOG_INCLUDE_API_GET=false
USER_ACCESS_LOG_METHODS=POST,PUT,PATCH,DELETE
CONFIG_SERVICE_CACHE_TTL_SECONDS=30
CONFIG_SERVICE_CACHE_MAX_KEYS=2048
GUNICORN_WORKERS=4
GUNICORN_THREADS=8
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=2

# Docket / case limits
CASE_DETAIL_HISTORY_LIMIT=200
CASE_DETAIL_DUE_LIMIT=200
CASE_DETAIL_FM_PER_PAGE=200
CASE_DETAIL_FM_MAX_PER_PAGE=500
CASE_LIST_SPLIT_QUERY_ENABLED=true
CASE_LIST_EXTRAS_CACHE_ENABLED=true
CASE_LIST_EXTRAS_CACHE_TTL_SECONDS=15

INTERNAL_EMAIL_DOMAINS=example.com

# Invoice / accounting
INVOICEAPP_INTEGRATED=1
INVOICEAPP_UNIFIED_CLIENTS=1
INVOICEAPP_CLIENT_SYNC_ENABLED=0
INVOICEAPP_DISABLE_ACCOUNTING_FEATURES=0
INVOICE_TIMELINE_TO_CASE_MEMO_ENABLED=0
AUTO_APPLY_BIZREG_TO_CLIENT=0
AUTO_APPLY_BIZREG_OVERWRITE=0
INVOICE_LIST_PY_FILTER_MAX_ROWS=20000

# Scheduler / workers
SCHEDULER_ENABLED=0
SCHEDULER_PROCESS_ROLE=worker
RUN_SCHEDULER=0
SCHEDULER_HEARTBEAT_INTERVAL_SECONDS=300
SCHEDULER_HEARTBEAT_GRACE_SECONDS=600
HOUSEKEEPING_RUN_ON_STARTUP=0
JOB_RUN_RETENTION_DAYS=90
JOB_RUN_SUCCESS_RETENTION_DAYS=14
DURABLE_JOB_RETENTION_DAYS=30
USER_ACCESS_LOG_RETENTION_DAYS=90
DISK_SAMPLE_RETENTION_DAYS=180

# Disk / error reporting
DISK_MONITOR_ENABLED=true
DISK_MONITOR_PATH=
DISK_ALERT_THRESHOLD_FREE_PERCENT=10.0
DISK_ALERT_COOLDOWN_MINUTES=60
DISK_ALERT_EMAILS=admin@example.com
ERROR_REPORTING_ENABLED=true
ERROR_REPORT_CAPTURE_LOGGED_EXCEPTIONS=true
ERROR_REPORT_ALERTS_ENABLED=false
ERROR_REPORT_ALERT_EMAILS=admin@example.com

# File parsing / storage
PDF_TEXT_CACHE_ENABLED=true
PDF_TEXT_CACHE_DIR=
ZIP_MAX_ENTRIES=200
ZIP_MAX_TOTAL_UNCOMPRESSED=52428800
ZIP_MAX_SINGLE_UNCOMPRESSED=20971520
ZIP_MAX_COMPRESSION_RATIO=100.0
# Legacy agency notice ZIP limits (optional)
LEGACY_NOTICE_ZIP_MAX_BYTES=104857600
LEGACY_NOTICE_ZIP_MAX_TOTAL_SIZE=104857600
STORAGE_TYPE=local

# Bank account inquiry / transaction import
BANK_ACCOUNT_DATA_PROVIDER=manual
BANK_ACCOUNT_BASE_CURRENCY=USD
PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ACCESS_TOKEN=
PLAID_ACCOUNT_IDS=
