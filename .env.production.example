# -----------------------------------------------------------------------------
# IP Docket System Production Environment Example
# -----------------------------------------------------------------------------

FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
BASE_URL=https://app.example.com
TIMEZONE=America/New_York
LOCALE=en-US
DATE_FORMAT=%m/%d/%Y
DATETIME_FORMAT=%m/%d/%Y %I:%M:%S %p
DATETIME_MINUTE_FORMAT=%m/%d/%Y %I:%M %p

# Local login
ALLOW_PASSWORD_LOGIN=true
LOCAL_ADMIN_BOOTSTRAP_ENABLED=false
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_INITIAL_PASSWORD
LOCAL_ADMIN_EMAIL=admin@example.com
LOCAL_ADMIN_DISPLAY_NAME=Administrator
ENABLE_TEST_ACCOUNTS=false
AUTH_REMEMBER_ENABLED=false

# Reverse proxy / network access
SECURITY_TRUST_PROXY_HEADERS=true
ADMIN_CIDR_ALLOWLIST=
INTERNAL_API_CIDR_ALLOWLIST=
CIDR_GUARD_ENABLED=true

# Database
DATABASE_URL=postgresql://ipm:CHANGE_ME_TO_A_STRONG_DB_PASSWORD@db-host:5432/ipm
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_WAIT_ON_START=true
DB_SCHEMA_AUTO_CREATE=0

# Redis / rate limiting
REDIS_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_REDIS_PASSWORD
RATELIMIT_STORAGE_URI=redis://:CHANGE_ME_TO_A_LONG_RANDOM_REDIS_PASSWORD@redis:6379/0
RATELIMIT_DEFAULTS="1000 per hour"
RATELIMIT_REQUIRE_SHARED_STORAGE=1

# Security policy
POLICY_ENGINE_ENABLED=true
POLICY_RAW_SQL_GUARD_MODE=enforce

INTERNAL_EMAIL_DOMAINS=example.com

# Runtime
PERF_HEADERS_ENABLED=false
CONFIG_SERVICE_CACHE_TTL_SECONDS=30
CONFIG_SERVICE_CACHE_MAX_KEYS=2048
USER_ACCESS_LOG_ENABLED=true
USER_ACCESS_LOG_ASYNC_ENABLED=true
USER_ACCESS_LOG_INCLUDE_API_GET=false
USER_ACCESS_LOG_METHODS=POST,PUT,PATCH,DELETE
GUNICORN_WORKERS=4
GUNICORN_THREADS=8
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=2
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100

# Scheduler
SCHEDULER_ENABLED=0
RUN_SCHEDULER=0
SCHEDULER_HEARTBEAT_INTERVAL_SECONDS=300
SCHEDULER_HEARTBEAT_GRACE_SECONDS=600
HOUSEKEEPING_RUN_ON_STARTUP=0

# Invoice/accounting
INVOICEAPP_INTEGRATED=1
INVOICEAPP_UNIFIED_CLIENTS=1
INVOICEAPP_DISABLE_ACCOUNTING_FEATURES=0
INVOICE_TIMELINE_TO_CASE_MEMO_ENABLED=0

# Error reporting
ERROR_REPORTING_ENABLED=true
ERROR_REPORT_CAPTURE_LOGGED_EXCEPTIONS=true
ERROR_REPORT_ALERTS_ENABLED=true
ERROR_REPORT_ALERT_THRESHOLD=3
ERROR_REPORT_ALERT_TOTAL_THRESHOLD=3
ERROR_REPORT_ALERT_WINDOW_MINUTES=60
ERROR_REPORT_ALERT_INTERVAL_MINUTES=15
ERROR_REPORT_ALERT_LIMIT=10
ERROR_REPORT_ALERT_EMAILS=admin@example.com

# Upload / image hardening
IMAGE_MAX_PIXELS=20000000
IMAGE_STRICT_DECOMPRESSION_BOMB=true
STORAGE_TYPE=local
# STORAGE_TYPE=s3
# S3_BUCKET=
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=sgp1

# Bank account inquiry / transaction import
BANK_ACCOUNT_DATA_PROVIDER=manual
BANK_ACCOUNT_BASE_CURRENCY=USD
PLAID_ENV=production
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ACCESS_TOKEN=
PLAID_ACCOUNT_IDS=
