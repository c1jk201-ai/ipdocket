    },
    {
      "id": "name_ref_contains_all_staff",
      "priority": 83,
      "match": {
        "category": [
          "WORK",
          "FILING",
          "EXAM",
          "REG",
          "REGISTRATION"
        ],
        "name_ref_contains": [
          "\ub4f1\ub85d",
          "\ub4f1\ub85d\ub9c8\uac10",
          "\uc2ec\uc0ac\uccad\uad6c",
          "\ucd9c\uc6d0",
          "\ucd9c\uc6d0\ub9c8\uac10",
          "\ud574\uc678\ucd9c\uc6d0\ub9c8\uac10"
        ]
      },
      "action": {
        "distribute_to": "all_staff"
      }
    },
    {
      "id": "name_free_contains_all_staff",
      "priority": 83,
      "match": {
        "category": [
          "WORK",
          "FILING",
          "EXAM",
          "REG",
          "REGISTRATION"
        ],
        "name_free_contains": [
          "\ub4f1\ub85d",
          "\ub4f1\ub85d\ub9c8\uac10",
          "\uc2ec\uc0ac\uccad\uad6c",
          "\ucd9c\uc6d0",
          "\ucd9c\uc6d0\ub9c8\uac10",
          "\ud574\uc678\ucd9c\uc6d0\ub9c8\uac10"
        ]
      },
      "action": {
        "distribute_to": "all_staff"
      }
    },
    {
      "id": "notice_ref_contains_office_action_due",
      "priority": 50,
      "match": {
        "category": [
          "NOTICE"
        ],
        "name_ref_contains": [
          "OFFICE_ACTION_DUE"
        ]
      },
      "action": {
        "distribute_to": "owner"
      }
    },
    {
      "id": "category_notice_owner",
      "priority": 49,
      "match": {
        "category": [
          "NOTICE"
        ]
      },
      "action": {
        "distribute_to": "owner"
      }
    },
    {
      "id": "category_v2_limit_owner",
      "priority": 48,
      "match": {
        "category": [
          "V2_LIMIT"
        ]
      },
      "action": {
